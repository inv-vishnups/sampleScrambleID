# Copy to ".env" in this directory; docker compose loads it automatically.
# Never commit real secrets.

JWT_SECRET=0123456789abcdef0123456789abcdef
SCIM_API_TOKEN=scrambleid-docker-token-change-me
APP_CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:8081
APP_COMPOSE_BOOTSTRAP_ADMIN=true
# Optional SCIM access audit (structured logs, no bodies)
# APP_SCIM_AUDIT_ENABLED=true
# APP_SCIM_AUDIT_VERBOSE_READS_AT_DEBUG=true
